{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auth Credentials",
  "description": "Authentication credentials and role matrix generated by Phase-3 auth_simulator",
  "type": "object",
  "required": [
    "generated_by",
    "credentials"
  ],
  "properties": {
    "generated_by": {
      "type": "string",
      "const": "auth_simulator"
    },
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "auth_method"
        ],
        "properties": {
          "role": {
            "type": "string",
            "description": "Role name: admin/editor/subscriber/anonymous"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "token": {
            "type": "string",
            "description": "JWT/session token"
          },
          "auth_method": {
            "type": "string",
            "enum": [
              "cookie",
              "bearer",
              "basic",
              "api_key"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "role_hierarchy": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "test_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "endpoint"
        ],
        "properties": {
          "action": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "expected_roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "test_with_roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
