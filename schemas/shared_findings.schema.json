{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shared Finding Entry",
  "description": "Single record of real-time shared findings between Phase-4 specialists (one per JSONL line)",
  "type": "object",
  "required": [
    "timestamp",
    "source_agent",
    "finding_type",
    "priority",
    "data"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_agent": {
      "type": "string",
      "description": "Source agent name (writer)"
    },
    "finding_type": {
      "type": "string",
      "enum": [
        "credential",
        "internal_url",
        "secret_key",
        "endpoint",
        "bypass_method",
        "config_value"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium"
      ]
    },
    "data": {
      "type": "object",
      "required": [
        "key",
        "value"
      ],
      "properties": {
        "key": {
          "type": "string",
          "description": "Finding name/identifier"
        },
        "value": {
          "type": "string",
          "description": "Finding value"
        },
        "context": {
          "type": "string",
          "description": "Context description of the finding"
        },
        "source_location": {
          "type": "string",
          "description": "Finding source file:line"
        }
      }
    },
    "target_agents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Suggested consumer agent names"
    },
    "consumed_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Agent names that consumed this finding"
    }
  }
}
