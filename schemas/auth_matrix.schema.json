{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auth Matrix",
  "description": "Authorization matrix: route + auth level + mechanism + bypass notes",
  "type": "object",
  "required": [
    "matrix"
  ],
  "properties": {
    "matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "route_id",
          "url",
          "auth_level",
          "auth_mechanism"
        ],
        "properties": {
          "route_id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "auth_level": {
            "type": "string",
            "enum": [
              "anonymous",
              "authenticated",
              "admin"
            ]
          },
          "auth_mechanism": {
            "type": "string"
          },
          "bypass_notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
