{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team4 Progress Tracker",
  "description": "Phase-4 specialist agent progress tracker, updated by specialists, read by main scheduler and QC-3",
  "type": "object",
  "required": [
    "experts",
    "status"
  ],
  "properties": {
    "experts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "agent_name",
          "task_id",
          "status"
        ],
        "properties": {
          "agent_name": {
            "type": "string",
            "description": "Specialist agent name"
          },
          "task_id": {
            "type": "string",
            "description": "Corresponding task ID"
          },
          "sink_type": {
            "type": "string",
            "description": "Assigned sink type"
          },
          "status": {
            "type": "string",
            "enum": [
              "waiting",
              "running",
              "completed",
              "failed",
              "timeout"
            ],
            "description": "Agent execution status"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "sinks_total": {
            "type": "integer",
            "description": "Total number of assigned sinks"
          },
          "sinks_completed": {
            "type": "integer",
            "description": "Number of completed sink audits"
          },
          "vulns_found": {
            "type": "integer",
            "description": "Number of vulnerabilities found"
          },
          "error_message": {
            "type": "string",
            "description": "Error message on failure"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "completed",
        "partial_failure"
      ],
      "description": "Overall Phase-4 status"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_experts": {
      "type": "integer"
    },
    "completed_experts": {
      "type": "integer"
    }
  }
}
