{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Priority Queue",
  "description": "Priority queue: P0-P3 / sink / source count / rating rationale",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "priority",
      "route_id",
      "route_url",
      "sink_function",
      "sink_file",
      "sink_line",
      "auth_level",
      "reason",
      "source_count",
      "sources"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^sink_\\d+$"
      },
      "priority": {
        "type": "string",
        "enum": [
          "P0",
          "P1",
          "P2",
          "P3"
        ]
      },
      "route_id": {
        "type": "string"
      },
      "route_url": {
        "type": "string"
      },
      "sink_function": {
        "type": "string"
      },
      "sink_file": {
        "type": "string"
      },
      "sink_line": {
        "type": "integer",
        "minimum": 1
      },
      "auth_level": {
        "type": "string",
        "enum": [
          "anonymous",
          "authenticated",
          "admin"
        ]
      },
      "reason": {
        "type": "string"
      },
      "source_count": {
        "type": "integer",
        "minimum": 1
      },
      "sources": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "sink_type": {
        "type": "string",
        "description": "Sink type (RCE/SQLi/XSS/LFI etc.)"
      },
      "cvss": {
        "type": "object",
        "description": "CVSS 3.1 score",
        "properties": {
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "vector": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM",
              "LOW",
              "NONE"
            ]
          }
        }
      },
      "attack_surface_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 100,
        "description": "Attack surface quantification score"
      },
      "business_impact": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Business impact labels"
      }
    }
  }
}
