{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business Logic Result",
  "description": "Business logic audit result output by business_logic_auditor specialist agent",
  "type": "object",
  "required": [
    "sink_id",
    "route_url",
    "specialist",
    "business_flow",
    "rounds_executed",
    "results",
    "final_verdict",
    "confidence"
  ],
  "properties": {
    "sink_id": {
      "type": "string",
      "pattern": "^sink_\\d+$",
      "description": "Associated priority_queue id"
    },
    "route_url": {
      "type": "string",
      "description": "Route path"
    },
    "specialist": {
      "type": "string",
      "const": "business_logic_auditor",
      "description": "Specialist agent name performing the audit"
    },
    "business_flow": {
      "type": "string",
      "description": "Description of affected business flow"
    },
    "rounds_executed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "round",
          "strategy",
          "payload",
          "business_impact",
          "state_before",
          "state_after",
          "persisted",
          "result"
        ],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "strategy": {
            "type": "string",
            "enum": [
              "price_tamper",
              "coupon_abuse",
              "payment_bypass",
              "flow_skip",
              "negative_value",
              "sms_bomb",
              "state_machine"
            ],
            "description": "Attack strategy"
          },
          "payload": {
            "type": "string",
            "description": "Actual payload sent"
          },
          "business_impact": {
            "type": "string",
            "description": "Business impact: financial loss / data leak / flow bypass etc."
          },
          "state_before": {
            "type": "string",
            "description": "State before operation"
          },
          "state_after": {
            "type": "string",
            "description": "State after operation"
          },
          "persisted": {
            "type": "boolean",
            "description": "Whether abnormal state is persisted"
          },
          "evidence_detail": {
            "type": [
              "string",
              "null"
            ],
            "description": "Evidence details"
          },
          "result": {
            "type": "string",
            "enum": [
              "confirmed",
              "suspected",
              "failed"
            ]
          }
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": [
        "confirmed",
        "suspected",
        "potential",
        "not_vulnerable"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
