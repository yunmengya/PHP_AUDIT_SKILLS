{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Race Condition Result",
  "description": "Race condition test result output by race_condition_auditor specialist agent",
  "type": "object",
  "required": [
    "sink_id",
    "route_url",
    "specialist",
    "test_type",
    "rounds_executed",
    "results",
    "final_verdict",
    "confidence"
  ],
  "properties": {
    "sink_id": {
      "type": "string",
      "pattern": "^sink_\\d+$",
      "description": "Associated priority_queue id"
    },
    "route_url": {
      "type": "string",
      "description": "Route path"
    },
    "specialist": {
      "type": "string",
      "const": "race_condition_auditor",
      "description": "Specialist agent name performing the attack"
    },
    "test_type": {
      "type": "string",
      "enum": [
        "TOCTOU",
        "double_spend",
        "token_replay",
        "rate_limit",
        "session_race",
        "db_transaction"
      ],
      "description": "Race condition test type"
    },
    "rounds_executed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "round",
          "strategy",
          "concurrent_requests",
          "total_attempts",
          "success_count",
          "success_rate",
          "time_window_ms",
          "payload",
          "result"
        ],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "strategy": {
            "type": "string",
            "description": "Strategy name"
          },
          "concurrent_requests": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of concurrent requests"
          },
          "total_attempts": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of attempts"
          },
          "success_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of successful triggers"
          },
          "success_rate": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Success rate"
          },
          "time_window_ms": {
            "type": "number",
            "minimum": 0,
            "description": "Attack time window in milliseconds"
          },
          "payload": {
            "type": "string",
            "description": "Actual payload sent"
          },
          "evidence_detail": {
            "type": [
              "string",
              "null"
            ],
            "description": "Evidence details"
          },
          "result": {
            "type": "string",
            "enum": [
              "confirmed",
              "suspected",
              "failed"
            ]
          },
          "baseline_comparison": {
            "type": "string",
            "description": "Comparison with normal request differences"
          }
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": [
        "confirmed",
        "suspected",
        "potential",
        "not_vulnerable"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
