{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PoC Summary",
  "description": "PoC script summary output by Phase-4.5 poc_generator",
  "type": "object",
  "required": [
    "generated_at",
    "total_confirmed",
    "poc_generated",
    "scripts"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_confirmed": {
      "type": "integer"
    },
    "poc_generated": {
      "type": "integer"
    },
    "poc_skipped": {
      "type": "integer"
    },
    "scripts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sink_id",
          "vuln_type",
          "file"
        ],
        "properties": {
          "sink_id": {
            "type": "string"
          },
          "vuln_type": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "description": "PoC script filename"
          },
          "endpoint": {
            "type": "string"
          },
          "auth_required": {
            "type": "boolean"
          },
          "curl_command": {
            "type": "string",
            "description": "Equivalent curl command"
          }
        }
      }
    }
  }
}
