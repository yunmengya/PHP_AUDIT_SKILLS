{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WordPress Result",
  "description": "WordPress audit result output by wordpress_auditor specialist agent",
  "type": "object",
  "required": [
    "sink_id",
    "specialist",
    "scope",
    "component_name",
    "component_version",
    "rounds_executed",
    "results",
    "final_verdict",
    "confidence"
  ],
  "properties": {
    "sink_id": {
      "type": "string",
      "pattern": "^sink_\\d+$",
      "description": "Associated priority_queue id"
    },
    "specialist": {
      "type": "string",
      "const": "wordpress_auditor",
      "description": "Specialist agent name performing the audit"
    },
    "scope": {
      "type": "string",
      "enum": [
        "core",
        "plugin",
        "theme"
      ],
      "description": "Audit scope"
    },
    "component_name": {
      "type": "string",
      "description": "WordPress core / plugin name / theme name"
    },
    "component_version": {
      "type": "string",
      "description": "Component version number"
    },
    "rounds_executed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "round",
          "strategy",
          "endpoint",
          "payload",
          "result"
        ],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "strategy": {
            "type": "string",
            "enum": [
              "core_cve",
              "plugin_audit",
              "xmlrpc",
              "rest_api",
              "shortcode",
              "nonce_bypass",
              "editor_rce"
            ],
            "description": "Attack strategy"
          },
          "endpoint": {
            "type": "string",
            "description": "Target endpoint"
          },
          "payload": {
            "type": "string",
            "description": "Actual payload sent"
          },
          "evidence_detail": {
            "type": [
              "string",
              "null"
            ],
            "description": "Evidence details"
          },
          "cve_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Associated CVE identifier"
          },
          "result": {
            "type": "string",
            "enum": [
              "confirmed",
              "suspected",
              "failed"
            ]
          }
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": [
        "confirmed",
        "suspected",
        "potential",
        "not_vulnerable"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
