{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WordPress Result",
  "description": "WordPress 审计结果，由 wordpress_auditor 专家 Agent 输出",
  "type": "object",
  "required": ["sink_id", "specialist", "scope", "component_name", "component_version", "rounds_executed", "results", "final_verdict", "confidence"],
  "properties": {
    "sink_id": {
      "type": "string",
      "pattern": "^sink_\\d+$",
      "description": "关联 priority_queue 的 id"
    },
    "specialist": {
      "type": "string",
      "const": "wordpress_auditor",
      "description": "执行审计的专家 Agent 名"
    },
    "scope": {
      "type": "string",
      "enum": ["core", "plugin", "theme"],
      "description": "审计范围"
    },
    "component_name": {
      "type": "string",
      "description": "WordPress 核心 / 插件名 / 主题名"
    },
    "component_version": {
      "type": "string",
      "description": "组件版本号"
    },
    "rounds_executed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["round", "strategy", "endpoint", "payload", "result"],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "strategy": {
            "type": "string",
            "enum": ["core_cve", "plugin_audit", "xmlrpc", "rest_api", "shortcode", "nonce_bypass", "editor_rce"],
            "description": "攻击策略"
          },
          "endpoint": {
            "type": "string",
            "description": "目标端点"
          },
          "payload": {
            "type": "string",
            "description": "实际发送的 Payload"
          },
          "evidence_detail": {
            "type": ["string", "null"],
            "description": "证据详情"
          },
          "cve_id": {
            "type": ["string", "null"],
            "description": "关联的 CVE 编号"
          },
          "result": {
            "type": "string",
            "enum": ["confirmed", "suspected", "failed"]
          }
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": ["confirmed", "suspected", "potential", "not_vulnerable"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  }
}
