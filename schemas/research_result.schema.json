{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mini-Researcher Result",
  "description": "Phase-4 Mini-Researcher Agent output format, stored at $WORK_DIR/research/{research_id}.json",
  "type": "object",
  "required": [
    "research_id",
    "query",
    "target_component",
    "findings",
    "recommendations",
    "confidence"
  ],
  "properties": {
    "research_id": {
      "type": "string",
      "pattern": "^research_\\d+$",
      "description": "Research ID, format: research_{timestamp}"
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Original research query"
    },
    "target_component": {
      "type": "string",
      "description": "Target component / framework / library name + version"
    },
    "context": {
      "type": "string",
      "description": "Context that triggered the research (auditor current state, failure reasons etc.)"
    },
    "trigger_condition": {
      "type": "string",
      "enum": [
        "MR-1",
        "MR-2",
        "MR-3",
        "MR-4",
        "MR-5"
      ],
      "description": "Trigger condition code (see phase4_attack_logic.md delegation mechanism table)"
    },
    "findings": {
      "type": "array",
      "description": "List of research findings",
      "items": {
        "type": "object",
        "required": [
          "type",
          "description",
          "source"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "cve",
              "exploit",
              "bypass_technique",
              "configuration",
              "general_intel"
            ],
            "description": "Finding type"
          },
          "id": {
            "type": "string",
            "description": "CVE ID or other identifier (e.g. CVE-2024-XXXXX)"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ],
            "description": "Severity level"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Vulnerability / technique description"
          },
          "affected_versions": {
            "type": "string",
            "description": "Affected version range (e.g. < 2.15.1)"
          },
          "exploit_available": {
            "type": "boolean",
            "description": "Whether public exploit code is available"
          },
          "exploit_method": {
            "type": "string",
            "description": "Exploit method overview"
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of exploit preconditions"
          },
          "payload_template": {
            "type": "string",
            "description": "Specific payload template (if available)"
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Information source (URL or local file path)"
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Recommended directions for the auditor to try"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "description": "Overall confidence: high=multi-source verified, medium=single reliable source, low=speculative"
    },
    "search_sources_used": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "known_cves.md",
          "lessons_learned.md",
          "framework_patterns.md",
          "attack_memory.db",
          "nvd_api",
          "github_advisory",
          "exploit_db",
          "web_search"
        ]
      },
      "description": "Information sources used in this research"
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 180,
      "description": "Research duration in seconds, max 180"
    }
  },
  "additionalProperties": false
}
