{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Environment Status",
  "description": "环境状态：框架/版本/路由分类/修复记录",
  "type": "object",
  "required": ["mode", "framework", "framework_version", "php_version", "db_type", "startup_rounds", "fixes_applied", "web_accessible", "routes_accessible", "routes_error", "routes_inaccessible", "xdebug_working", "db_tables_total", "db_tables_from_migration", "db_tables_from_inference", "disabled_features", "encrypted_files"],
  "properties": {
    "mode": { "type": "string", "enum": ["full", "partial"] },
    "framework": { "type": "string", "enum": ["Laravel", "ThinkPHP", "Yii2", "Symfony", "CakePHP", "CodeIgniter", "Native"] },
    "framework_version": { "type": "string" },
    "php_version": { "type": "string" },
    "db_type": { "type": "string", "enum": ["mysql", "pgsql", "sqlite"] },
    "startup_rounds": { "type": "integer", "minimum": 1 },
    "fixes_applied": { "type": "array", "items": { "type": "string" } },
    "web_accessible": { "type": "boolean" },
    "routes_accessible": { "type": "integer", "minimum": 0 },
    "routes_error": { "type": "integer", "minimum": 0 },
    "routes_inaccessible": { "type": "integer", "minimum": 0 },
    "routes_error_details": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "error", "reason", "impact"],
        "properties": {
          "route": { "type": "string" },
          "error": { "type": "string" },
          "reason": { "type": "string" },
          "impact": { "type": "string" }
        }
      }
    },
    "xdebug_working": { "type": "boolean" },
    "db_tables_total": { "type": "integer", "minimum": 0 },
    "db_tables_from_migration": { "type": "integer", "minimum": 0 },
    "db_tables_from_inference": { "type": "integer", "minimum": 0 },
    "disabled_features": { "type": "array", "items": { "type": "string" } },
    "encrypted_files": { "type": "array", "items": { "type": "string" } },
    "version_alerts": {
      "type": "array",
      "description": "版本安全预判结果 — env_detective 将检测到的框架+PHP版本与 known_cves.md 交叉后生成",
      "items": {
        "type": "object",
        "required": ["component", "detected_version", "cve_id", "severity", "description", "affected_auditors"],
        "properties": {
          "component": { "type": "string", "description": "受影响组件，如 Laravel / ThinkPHP / PHP" },
          "detected_version": { "type": "string", "description": "检测到的版本号" },
          "cve_id": { "type": "string", "description": "CVE 编号" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "description": { "type": "string", "description": "漏洞简述" },
          "affected_auditors": { "type": "array", "items": { "type": "string" }, "description": "应优先分配的 auditor 列表" }
        }
      }
    }
  }
}
