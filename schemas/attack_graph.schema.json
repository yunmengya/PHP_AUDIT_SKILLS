{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Attack Graph",
  "description": "Attack graph output by attack-graph-builder",
  "type": "object",
  "required": [
    "generated_at",
    "total_nodes",
    "total_edges",
    "total_paths",
    "nodes",
    "edges",
    "paths"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_nodes": {
      "type": "integer",
      "description": "Total number of vulnerability nodes"
    },
    "total_edges": {
      "type": "integer",
      "description": "Total number of relationship edges"
    },
    "total_paths": {
      "type": "integer",
      "description": "Total number of attack paths"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "vuln_type",
          "endpoint",
          "confidence",
          "severity"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^V-\\d+$"
          },
          "vuln_type": {
            "type": "string"
          },
          "sub_type": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "confirmed",
              "highly_suspected",
              "potential_risk"
            ]
          },
          "output_data": {
            "type": "string",
            "description": "Data/capabilities produced by this vulnerability"
          },
          "required_access": {
            "type": "string",
            "enum": [
              "anonymous",
              "authenticated",
              "admin"
            ]
          },
          "grants_access": {
            "type": "string",
            "description": "Access level granted"
          },
          "severity": {
            "type": "string",
            "enum": [
              "Critical",
              "High",
              "Medium",
              "Low",
              "Info"
            ]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "relationship"
        ],
        "properties": {
          "from": {
            "type": "string",
            "description": "Source node_id"
          },
          "to": {
            "type": "string",
            "description": "Target node_id"
          },
          "relationship": {
            "type": "string",
            "enum": [
              "credential_reuse",
              "token_forge",
              "privilege_escalation",
              "data_extraction",
              "lateral_movement"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path_id",
          "score",
          "confidence",
          "nodes",
          "entry_point",
          "final_impact"
        ],
        "properties": {
          "path_id": {
            "type": "string",
            "pattern": "^P-\\d+$"
          },
          "score": {
            "type": "number",
            "description": "Path score"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "nodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered list of node_ids"
          },
          "entry_point": {
            "type": "string"
          },
          "final_impact": {
            "type": "string"
          },
          "narrative": {
            "type": "string",
            "description": "Attack narrative"
          },
          "remediation_priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          }
        }
      }
    },
    "escalation_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern_name": {
            "type": "string"
          },
          "involved_vulns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "individual_severity": {
            "type": "string"
          },
          "combined_severity": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "mermaid_diagram": {
      "type": "string",
      "description": "Complete Mermaid diagram code"
    }
  }
}
