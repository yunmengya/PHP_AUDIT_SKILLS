{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NoSQL Result",
  "description": "NoSQL injection test result output by nosql_auditor specialist agent",
  "type": "object",
  "required": [
    "sink_id",
    "route_url",
    "specialist",
    "db_type",
    "rounds_executed",
    "results",
    "final_verdict",
    "confidence"
  ],
  "properties": {
    "sink_id": {
      "type": "string",
      "pattern": "^sink_\\d+$",
      "description": "Associated priority_queue id"
    },
    "route_url": {
      "type": "string",
      "description": "Route path"
    },
    "specialist": {
      "type": "string",
      "const": "nosql_auditor",
      "description": "Specialist agent name performing the attack"
    },
    "db_type": {
      "type": "string",
      "enum": [
        "mongodb",
        "redis",
        "elasticsearch",
        "memcached"
      ],
      "description": "NoSQL database type"
    },
    "rounds_executed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "round",
          "strategy",
          "payload",
          "injection_point",
          "request",
          "response_status",
          "response_body_snippet",
          "query_semantic_change",
          "result"
        ],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "strategy": {
            "type": "string",
            "enum": [
              "operator_injection",
              "where_js",
              "regex_dos",
              "aggregation",
              "json_pollution",
              "redis_crlf",
              "orm_bypass"
            ],
            "description": "Attack strategy"
          },
          "payload": {
            "type": "string",
            "description": "Actual payload sent"
          },
          "injection_point": {
            "type": "string",
            "description": "Injection point description"
          },
          "request": {
            "type": "string",
            "description": "Complete HTTP request"
          },
          "response_status": {
            "type": "integer",
            "description": "HTTP response status code"
          },
          "response_body_snippet": {
            "type": "string",
            "description": "First 500 characters of response body"
          },
          "query_semantic_change": {
            "type": "boolean",
            "description": "Whether query semantics were altered"
          },
          "evidence_detail": {
            "type": [
              "string",
              "null"
            ],
            "description": "Evidence details"
          },
          "result": {
            "type": "string",
            "enum": [
              "confirmed",
              "suspected",
              "failed"
            ]
          }
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": [
        "confirmed",
        "suspected",
        "potential",
        "not_vulnerable"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
