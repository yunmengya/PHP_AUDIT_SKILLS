{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Correlation Report",
  "description": "Cross-auditor correlation analysis report output by correlation-engine",
  "type": "object",
  "required": [
    "generated_at",
    "total_findings",
    "false_positives_removed",
    "chains",
    "summary"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_findings": {
      "type": "integer"
    },
    "false_positives_removed": {
      "type": "integer"
    },
    "chains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chain_id",
          "vulns",
          "combined_impact",
          "confidence"
        ],
        "properties": {
          "chain_id": {
            "type": "string"
          },
          "vulns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "combined_impact": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "second_order_vulns": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "string"
    },
    "graph_correlations": {
      "type": "object",
      "description": "Relational memory graph consumption results (rule category 4.5 output)",
      "properties": {
        "data_flow_chains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_node": {
                "type": "string"
              },
              "target_node": {
                "type": "string"
              },
              "relation": {
                "type": "string"
              },
              "source_status": {
                "type": "string"
              },
              "target_status": {
                "type": "string"
              },
              "escalated_severity": {
                "type": "string"
              }
            }
          },
          "description": "Data flow attack chains discovered via data_flows_to edges"
        },
        "reassessment_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "node_id": {
                "type": "string"
              },
              "sink_id": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "enabled_by": {
                "type": "string"
              }
            }
          },
          "description": "Sinks requiring reassessment due to satisfied prerequisites"
        },
        "escalations_from_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_node": {
                "type": "string"
              },
              "target_node": {
                "type": "string"
              },
              "original_severities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "combined_severity": {
                "type": "string"
              }
            }
          },
          "description": "Combined severity escalations based on escalates_to edges"
        },
        "high_value_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "data_object",
              "vuln_count"
            ],
            "properties": {
              "data_object": {
                "type": "string"
              },
              "vuln_count": {
                "type": "integer",
                "minimum": 3
              },
              "vuln_types": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "max_severity": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              }
            }
          },
          "description": "High-value targets with ≥3 vulnerabilities on the same data object"
        },
        "historical_pattern_matches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string"
              },
              "matched_from_project": {
                "type": "string"
              },
              "suggestion": {
                "type": "string"
              }
            }
          },
          "description": "Cross-project historical pattern matches"
        }
      }
    }
  }
}
