{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credentials",
  "description": "凭证池：anonymous/authenticated/admin",
  "type": "object",
  "required": ["anonymous", "authenticated", "admin"],
  "properties": {
    "anonymous": { "type": "object" },
    "authenticated": {
      "type": "object",
      "required": ["method", "username"],
      "properties": {
        "method": { "type": "string", "enum": ["cookie", "jwt", "session"] },
        "cookie": { "type": ["string", "null"] },
        "token": { "type": ["string", "null"] },
        "user_id": { "type": ["integer", "null"] },
        "username": { "type": "string" }
      }
    },
    "admin": {
      "type": "object",
      "required": ["method", "username"],
      "properties": {
        "method": { "type": "string", "enum": ["cookie", "jwt", "session"] },
        "cookie": { "type": ["string", "null"] },
        "token": { "type": ["string", "null"] },
        "user_id": { "type": ["integer", "null"] },
        "username": { "type": "string" }
      }
    }
  }
}
