{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Crypto Audit Result",
  "description": "Cryptographic audit result output by crypto_auditor specialist agent",
  "type": "object",
  "required": [
    "sink_id",
    "category",
    "specialist",
    "rounds_executed",
    "results",
    "final_verdict",
    "confidence"
  ],
  "properties": {
    "sink_id": {
      "type": "string",
      "pattern": "^sink_\\d+$",
      "description": "Associated priority_queue id"
    },
    "category": {
      "type": "string",
      "enum": [
        "password_hashing",
        "random_number",
        "encryption",
        "jwt",
        "session_token",
        "signature",
        "key_management"
      ],
      "description": "Cryptographic audit category"
    },
    "specialist": {
      "type": "string",
      "const": "crypto_auditor",
      "description": "Specialist agent name performing the audit"
    },
    "rounds_executed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "round",
          "strategy",
          "target_function",
          "target_file",
          "target_line",
          "weakness",
          "evidence",
          "exploitability",
          "result"
        ],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "strategy": {
            "type": "string",
            "description": "Strategy name"
          },
          "target_function": {
            "type": "string",
            "description": "Cryptographic function under audit"
          },
          "target_file": {
            "type": "string",
            "description": "File path"
          },
          "target_line": {
            "type": "integer",
            "minimum": 1,
            "description": "Line number"
          },
          "weakness": {
            "type": "string",
            "description": "Weakness description"
          },
          "evidence": {
            "type": "string",
            "description": "Evidence: predictable output / weak key / algorithm downgrade etc."
          },
          "exploitability": {
            "type": "string",
            "enum": [
              "直接可利用",
              "需要条件",
              "理论可能"
            ],
            "description": "Exploitability level"
          },
          "result": {
            "type": "string",
            "enum": [
              "confirmed",
              "suspected",
              "failed"
            ]
          }
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": [
        "confirmed",
        "suspected",
        "potential",
        "not_vulnerable"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
